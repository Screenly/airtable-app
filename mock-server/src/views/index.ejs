<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Airtable Mock Server</title>
    <link rel="stylesheet" href="/css/main.css" />
    <style>[x-cloak] { opacity: 0; }</style>
    <script src="/vendor/htmx/htmx.min.js"></script>
    <script src="/vendor/lucide/lucide.min.js"></script>
    <script src="/js/app.js" defer></script>
    <script src="/vendor/alpine/cdn.min.js" defer></script>
  </head>
  <body class="min-h-screen bg-[#0a0a1a] text-[#e0e0e0] flex items-center justify-center p-8 font-sans">

    <% if (tokens) { %>
      <div class="flex flex-row w-full max-w-4xl rounded-3xl overflow-hidden border border-white/20 text-white"
        x-data="tokenViewer">
        <span id="data-access-token" style="display:none"><%= tokens.access_token %></span>
        <span id="data-refresh-token" style="display:none"><%= tokens.refresh_token %></span>

        <div class="flex-none w-80 bg-[#2d7ff9]/10 border-r border-white/20 px-10 py-12 flex flex-col justify-center gap-4">
          <h1 class="text-4xl font-bold leading-tight text-white m-0">Connected to<br />Airtable</h1>
          <p class="text-base text-white/85 m-0 leading-relaxed">Tokens are ready for the Edge App.</p>
          <span class="text-xs font-semibold uppercase tracking-widest text-white bg-[#00a389] px-3 py-1 rounded-full self-start">&#10003; Authenticated</span>
        </div>

        <div class="flex-1 min-w-0 px-10 py-12 flex flex-col justify-center gap-5">
          <%- include('partials/token-field', { label: 'Access Token', key: 'access', value: tokens.access_token }) %>
          <%- include('partials/token-field', { label: 'Refresh Token', key: 'refresh', value: tokens.refresh_token }) %>

          <div class="relative mb-5">
            <div class="text-xs text-white/45 uppercase tracking-widest mb-1.5">Granted Scopes</div>
            <div class="bg-white/5 border border-white/10 rounded-lg py-2.5 pr-3 pl-3 font-mono text-xs text-[#a0cfff] break-all leading-relaxed"><%= tokens.scope %></div>
          </div>

          <div class="flex gap-3 items-center flex-wrap mt-4 justify-end">
            <form method="POST" action="/start" class="m-0">
              <button type="submit" class="inline-block min-w-[10rem] px-5 py-2.5 rounded-full text-sm font-semibold cursor-pointer border-0 no-underline bg-[#2d7ff9] text-white hover:bg-[#1a6fe0]">Reconnect</button>
            </form>
            <form method="POST" action="/clear" class="m-0">
              <button type="submit" class="inline-block min-w-[10rem] px-5 py-2.5 rounded-full text-sm font-semibold cursor-pointer border-0 no-underline bg-[#ff5050] text-white hover:bg-[#e03c3c]">Disconnect</button>
            </form>
          </div>
        </div>
      </div>

    <% } else { %>
      <div class="flex flex-row w-full max-w-4xl rounded-3xl overflow-hidden border border-white/20 text-white">
        <div class="flex-none w-80 bg-[#2d7ff9]/10 border-r border-white/20 px-10 py-12 flex flex-col justify-center gap-4">
          <h1 class="text-4xl font-bold leading-tight text-white m-0">Connect to<br />Airtable</h1>
          <p class="text-base text-white/85 m-0 leading-relaxed">Authorize this screen to display your Airtable data.</p>
        </div>

        <div class="flex-1 px-10 py-12 flex flex-col justify-center gap-5">
          <p class="text-white/50 m-0 mb-6">No tokens stored yet. Click below to authorize with Airtable.</p>
          <form method="POST" action="/start" class="m-0">
            <button type="submit" class="inline-block min-w-[10rem] px-5 py-2.5 rounded-full text-sm font-semibold cursor-pointer border-0 no-underline bg-[#2d7ff9] text-white hover:bg-[#1a6fe0]">Connect to Airtable</button>
          </form>
        </div>
      </div>
    <% } %>

  </body>
</html>
