<div x-show="disconnectOpen" x-cloak
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/60"
  @keydown.escape.window="disconnectOpen = false">
  <div class="bg-[#1a1a2e] border border-white/15 rounded-2xl p-8 w-full max-w-sm shadow-2xl"
    @click.outside="disconnectOpen = false">
    <h2 class="text-lg font-semibold text-white m-0 mb-3">Disconnect from Airtable?</h2>
    <p class="text-sm text-white/60 m-0 mb-7 leading-relaxed">Your stored tokens will be deleted. You will need to re-authorize to reconnect.</p>
    <div class="flex gap-3 justify-end">
      <button @click="disconnectOpen = false"
        class="px-5 py-2.5 rounded-full text-sm font-semibold cursor-pointer border border-white/20 bg-transparent text-white/70 hover:text-white">Cancel</button>
      <button hx-post="/clear" @click="disconnectOpen = false"
        class="px-5 py-2.5 rounded-full text-sm font-semibold cursor-pointer border-0 bg-[#ff5050] text-white hover:bg-[#e03c3c]">Disconnect</button>
    </div>
  </div>
</div>
